    },
    {
      "stage_id": "conflict_synthesis",
      "fault_types": ["claim_cluster_fault", "target_binding_fault", "argument_relation_fault", "conflict_resolution_fault"],
      "trace_surface": ["ConflictMap.claims", "ConflictMap.targets", "ConflictMap.arguments", "ConflictMap.edges", "ConflictMap.resolution_summary"]
    },
    {
      "stage_id": "mechanism_analysis",
      "fault_types": ["path_identification_fault", "bridge_node_fault", "phase_shift_fault", "mechanism_synthesis_fault"],
      "trace_surface": ["MechanismSummary.amplification_paths", "MechanismSummary.bridge_nodes", "MechanismSummary.phase_shifts", "MechanismSummary.cause_candidates"]
